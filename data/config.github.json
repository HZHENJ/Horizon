{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-pro",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1,
    "languages": [
      "zh",
      "en"
    ],
    "analysis_concurrency": 10,
    "enrichment_concurrency": 10
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 150
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "Semianalysis",
        "url": "https://newsletter.semianalysis.com/feed",
        "enabled": true,
        "category": "semiconductors"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": false,
        "category": "linux-kernel"
      },
      {
        "name": "Brendan Gregg",
        "url": "https://www.brendangregg.com/blog/rss.xml",
        "enabled": true,
        "category": "systems"
      },
      {
        "name": "Nature",
        "url": "https://www.nature.com/nature.rss",
        "enabled": false,
        "category": "science"
      },
      {
        "name": "Quanta Magazine",
        "url": "https://api.quantamagazine.org/feed/",
        "enabled": false,
        "category": "science"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "zaihuapd",
          "enabled": true,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled":false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 15,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled":true,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "equities",
          "symbols": ["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA"]
        },
        {
          "name": "ai-infra",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "ai",
          "symbols": ["NVDA", "AMD", "AVGO", "TSM", "PLTR", "CRM"]
        },
        {
          "name": "chip-leaders",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "semiconductors",
          "symbols": ["NVDA", "AMD", "TSM", "AVGO", "INTC", "ASML"]
        },
        {
          "name": "cloud-platforms",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "cloud",
          "symbols": ["MSFT", "AMZN", "GOOGL", "ORCL", "SAP", "IBM"]
        },
        {
          "name": "china-tech",
          "enabled": false,
          "provider": "yfinance",
          "fetch_limit": 15,
          "category": "china-tech",
          "symbols": ["BABA", "TCEHY", "JD", "PDD", "BIDU", "NTES"]
        },
        {
          "name": "energy",
          "enabled": false,
          "provider": "yfinance",
          "fetch_limit": 15,
          "category": "energy",
          "symbols": ["XOM", "CVX", "SLB", "COP", "EOG"]
        }
      ]
    },
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript", "Go"],
      "keywords": [],
      "min_stars": 10,
      "max_items": 30
    },
    "gdelt": {
      "enabled": false,
      "query": "artificial intelligence",
      "mode": "ArtList",
      "max_records": 70,
      "timespan": null,
      "language": null,
      "country": null,
      "category": "news"
    },
    "google_news": {
      "enabled": true,
      "query": "artificial intelligence",
      "language": "en",
      "country": "US",
      "ceid": null,
      "max_results": 100,
      "category": "news"
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
